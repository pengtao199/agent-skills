source 'https://github.com/CocoaPods/Specs.git'

platform :ios, '13.0'

target 'YourAppTarget' do
  use_frameworks!

  # Replace versions with the exact output generated by the TopOn portal.
  pod 'TPNiOS', '__TOPON_CORE_VERSION__'

  # Debug only. Remove before release.
  # pod 'TPNDebugUISDK', '__DEBUG_UI_VERSION__'

  # Keep only the adapters you actually selected in the TopOn portal.
  pod 'TPNMediationAdxSmartdigimktAdapter', '__ADX_VERSION__'
  pod 'TPNMediationAdmobAdapter', '__ADMOB_VERSION__'
  # pod 'TPNMediationMintegralAdapter', '__MINTEGRAL_VERSION__'
  # pod 'TPNMediationVungleAdapter', '__VUNGLE_VERSION__'

  post_install do |installer|
    installer.generated_projects.each do |project|
      project.targets.each do |target|
        target.build_configurations.each do |config|
          config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
        end
      end
    end
  end
end
